# Vendored subcharts + packaged artifacts (produced by helm dependency build /
# helm package). They are pulled fresh from upstream and rebuilt on demand.
charts/istio/charts/
charts/istio/Chart.lock
dist/
*.tgz

# Generated secret rendered from the GHCR OCI repo-secret template at apply time.
# Never commit a real token.
gitops/argocd/install/.ghcr-repo-secret.generated.yaml

# Kubeconfig / local state
kubeconfig
*.kubeconfig
.env

# app-a Node build artifacts (produced by npm ci / tsc / docker build).
demo/app-a/app/node_modules/
demo/app-a/app/dist/

# harness build output + persisted measurement result.
harness/bin/
results.json
